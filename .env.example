# ═══════════════════════════════════════════════════════════════
#  Environment — copy this to .env and fill in real values
#  Generate secrets with: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════

# ─── Domain (point DNS A records for app., api., n8n. here) ────
DOMAIN=yourdomain.com
TZ=America/Chicago

# ─── Postgres ──────────────────────────────────────────────────
PG_USER=workspace
PG_PASSWORD=change_me_long_random_string
PG_DB=workspace

# ─── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_long_random_string

# ─── MinIO (S3) ────────────────────────────────────────────────
MINIO_USER=workspace_admin
MINIO_PASSWORD=change_me_long_random_string

# ─── MeiliSearch ───────────────────────────────────────────────
MEILI_KEY=change_me_long_random_string

# ─── App secrets ───────────────────────────────────────────────
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# ─── n8n ───────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=change_me_long_random_string
N8N_USER=admin
N8N_PASSWORD=change_me_strong_password

# ─── Optional: Groq free tier as voice-mode LLM fallback ──────
# Get a key at https://console.groq.com (free)
GROQ_API_KEY=

# ─── Web Push (VAPID) ─────────────────────────────────────────
# Generate both keys at once:
#   docker run --rm node:20-alpine npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Backups (restic) ─────────────────────────────────────────
# Free option: Storj (25 GB free) or rotate between two servers via SFTP
# RESTIC_REPOSITORY=sftp:backup@other-host:/backups/workspace
# RESTIC_REPOSITORY=b2:your-bucket:/workspace
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
# If using Backblaze B2:
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=
